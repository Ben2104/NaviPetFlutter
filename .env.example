# Mapbox PUBLIC access token (pk.*). Get one at https://account.mapbox.com/access-tokens/
# Copy this file to `.env` and fill in your token. This is the RUNTIME token used
# to display the map. It is loaded by flutter_dotenv and passed to the SDK in
# lib/main.dart.
#
# NOTE: The native Mapbox SDK ALSO requires a separate SECRET download token
# (sk.* with the DOWNLOADS:READ scope) to build the app. That one does NOT go
# here — see the README "Mapbox setup" section for where it goes.
MAPBOX_PUBLIC_TOKEN=your_mapbox_public_token_here
